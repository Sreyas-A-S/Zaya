          "title": "Medical History",
          "fields": [
            {
              "key": "co_morbidities",
              "label": "Co-morbidities – Hypertension, obesity, cardiac issues, diabetes, thyroid",
              "type": "multi_select_with_other",
              "options": [
                "Hypertension",
                "Obesity",
                "Cardiac issues",
                "Diabetes",
                "Thyroid"
              ]
            },
            {
              "key": "psychiatric_history_personal_family",
              "label": "Psychiatric history (personal & family)",
              "type": "textarea"
            },
            {
              "key": "substance_history",
              "label": "Substance history",
              "type": "textarea"
            },
            {
              "key": "sleep_pattern",
              "label": "Sleep pattern",
              "type": "textarea"
            },
            {
              "key": "appetite",
              "label": "Appetite",
              "type": "textarea"
            }
          ]
        },
        {
          "subsection_id": "4.2",
          "title": "Risk Screening",
          "mandatory": true,
          "tool_reference": "ASQ-style Suicide Risk Screening",
          "fields": [
            {
              "key": "q1",
              "label": "In the past few weeks, have you wished you were dead?",
              "type": "radio",
              "options": ["Yes", "No"]
            },
            {
              "key": "q2",
              "label": "In the past few weeks, have you felt that you or your family would be better off if you were dead?",
              "type": "radio",
              "options": ["Yes", "No"]
            },
            {
              "key": "q3",
              "label": "In the past week, have you been having thoughts about killing yourself?",
              "type": "radio",
              "options": ["Yes", "No"]
            },
            {
              "key": "q4",
              "label": "Have you ever tried to kill yourself?",
              "type": "radio",
              "options": ["Yes", "No"]
            },
            {
              "key": "q4_recent_attempt",
              "label": "If yes, when was the most recent attempt?",
              "type": "radio",
              "options": [
                "Within last 12 months",
                "Over 1 year ago"
              ],
              "conditional_on": "q4 = Yes"
            },
            {
              "key": "q5",
              "label": "Are you having thoughts of killing yourself right now?",
              "type": "radio",
              "options": ["Yes", "No"],
              "conditional_rule": "Ask if patient answers Yes to any of Questions #1 through #4"
            },
            {
              "key": "q5_if_yes_describe",
              "label": "If yes, describe briefly",
              "type": "textarea",
              "conditional_on": "q5 = Yes"
            },
            {
              "key": "screening_result",
              "label": "Screening result and next steps",
              "type": "computed",
              "logic": [
                {
                  "if": "No to all Questions #1-#4",
                  "result": "Negative screen",
                  "next_step": "No intervention is necessary at this time. NOTE: Clinical judgment can always override a negative screen."
                },
                {
                  "if": "Yes to any of Questions #1-#4 AND Yes to Question #5",
                  "result": "Acute positive screen (imminent/acute risk identified)",
                  "next_step": [
                    "Patient requires a STAT/urgent safety/full mental health evaluation.",
                    "Patient cannot leave until evaluated for safety.",
                    "Keep patient in sight.",
                    "Remove dangerous objects from room (if possible).",
                    "Alert clinician responsible for patient’s care."
                  ]
                },
                {
                  "if": "Yes to any of Questions #1-#4 AND No to Question #5",
                  "result": "Non-acute positive screen (potential risk identified)",
                  "next_step": [
                    "Patient needs a brief suicide safety assessment to determine if a full mental health evaluation is needed (and when).",
                    "Non-acute positive status does NOT require 1-to-1 observation while patient is awaiting further assessment (unless there are other safety concerns).",
                    "Alert clinician responsible for patient’s care."
                  ]
                }
              ]
            },
            {
              "key": "refused_to_answer",
              "label": "If patient refuses to answer screening questions",
              "type": "checkbox"
            },
            {
              "key": "refusal_guidance",
              "label": "Refusal Guidance",
              "type": "info",
              "value": [
                "For youth, refusal is considered a non-acute positive screen.",
                "For adults, refusal is NOT considered a positive screen unless there are other safety concerns.",
                "Document the refusal."
              ]
            },
            {
              "key": "resources_given",
              "label": "Provide resources to all patients",
              "type": "checkbox"
            },
            {
              "key": "resources_list",
              "label": "Resources",
              "type": "info",
              "value": [
                "988 Suicide and Crisis Lifeline",
                "Crisis Text Line"
              ]
            },
            {
              "key": "risk_notes",
              "label": "Referral Notes / Safety Notes / Clinician Notes",
              "type": "textarea"
            }
          ]
        }
      ]
    }
  ]
